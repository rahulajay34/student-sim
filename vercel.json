{
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "client/dist",
        "installCommand": "npm install",
        "buildCommand": "npm run build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/sessions/:id/message",
      "destination": "https://PROJECT_REF.supabase.co/functions/v1/session/api/sessions/:id/message"
    },
    {
      "source": "/api/sessions/:id/observe",
      "destination": "https://PROJECT_REF.supabase.co/functions/v1/session/api/sessions/:id/observe"
    },
    {
      "source": "/api/sessions/:id/cue",
      "destination": "https://PROJECT_REF.supabase.co/functions/v1/session/api/sessions/:id/cue"
    },
    {
      "source": "/api/sessions/:id/realtime/openai-token",
      "destination": "https://PROJECT_REF.supabase.co/functions/v1/session/api/sessions/:id/realtime/openai-token"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://PROJECT_REF.supabase.co/functions/v1/api/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
